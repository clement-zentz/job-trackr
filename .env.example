# .env.example
# --- Database ---
# PostgreSQL container initialization values.
# Keep DATABASE_URL in sync with these values.
POSTGRES_USER=dev_user
POSTGRES_PASSWORD=dev_password
POSTGRES_DB=dev_database
# --- Django ---
DJANGO_SETTINGS_MODULE=job_trackr.settings.dev
DJANGO_SECRET_KEY='your_django_secret_key123'
ALLOWED_HOSTS=localhost,127.0.0.1,backend
DATABASE_URL=postgres://dev_user:dev_password@database:5432/dev_database
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
